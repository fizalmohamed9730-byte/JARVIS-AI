# ============================================
# JARVIS Environment Configuration
# ============================================
# Copy this file to .env and update the values

# ============================================
# Application Settings
# ============================================
APP_NAME=JARVIS
ENVIRONMENT=development
SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=true
LOG_LEVEL=INFO

# ============================================
# Server Settings
# ============================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# FRONTEND_PORT is used by the frontend dev server
FRONTEND_PORT=5173

# ============================================
# Database Settings
# ============================================
DATABASE_URL=postgresql://jarvis:jarvis@localhost:5432/jarvis_db
POSTGRES_DB=jarvis_db
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=jarvis_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ============================================
# Redis Settings
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# AI/ML Settings
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_VISION_MODEL=gpt-4-vision-preview

# Local model settings (optional)
LOCAL_MODEL_PATH=
USE_LOCAL_MODEL=false

# ============================================
# Vision Settings
# ============================================
WEBCAM_INDEX=0
SCREENSHOT_QUALITY=95
DETECTION_THRESHOLD=0.5

# ============================================
# API Keys (Optional)
# ============================================
WEATHER_API_KEY=your-openweathermap-api-key
NEWS_API_KEY=your-newsapi-key

# ============================================
# CORS Settings
# ============================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_PER_MINUTE=100
CHAT_RATE_LIMIT_PER_MINUTE=30

# ============================================
# Storage Settings
# ============================================
STORAGE_PATH=./data
LOG_PATH=./logs
MODELS_PATH=./models

# ============================================
# Authentication
# ============================================
JWT_SECRET_KEY=change-this-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# Email Settings (Optional)
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@jarvis.local

# ============================================
# Docker Settings
# ============================================
COMPOSE_PROJECT_NAME=jarvis
